# 🌍 Application Configuration
PORT=3000

# 🛢️ Database Configuration
DB_PROVIDER=mongo        # Options: "mongo" or "postgres"

# MongoDB Configuration
MONGO_URI=mongodb://admin:admin@localhost:27017/mintflow  # Add credentials if needed

# PostgreSQL Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=mintflow
POSTGRES_URI=postgres://admin:admin@localhost:5432/mintflow  # Ensure no double colons "::"

# 🚀 Redis/KeyDB Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=             # Set password if required
REDIS_DB=0

# 🧠 Vector Database Configuration
VECTOR_DB_PROVIDER=weaviate  # Options: "weaviate", "pinecone", etc.

# Weaviate Configuration
WEAVIATE_HOST=http://localhost:8080
WEAVIATE_API_KEY=             # If authentication is enabled

# Pinecone Configuration (If using Pinecone)
PINECONE_API_KEY=YOUR_PINECONE_KEY
PINECONE_ENV=YOUR_PINECONE_ENV
PINECONE_INDEX=phd-index

# 🔑 Security & Authentication
JWT_SECRET=your_jwt_secret
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# 📡 API Keys (if required)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# 🛠 Miscellaneous Config
LOG_LEVEL=info  # Options: "debug", "info", "warn", "error"
NODE_ENV=development  # Options: "development", "production", "test"
